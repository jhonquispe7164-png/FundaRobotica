<?xml version="1.0"?>
<launch>
  <!--Ejecutar esta linea de code despues de lanzar este launch en una nueva terminal 
  
    $ ros2 run ros_gz_sim create -name mobile_bot -topic robot_description -z 0.1

    este inserta el robot al mundo 
  -->
  <let name="robot_description"
       value="$(command 'xacro $(find-pkg-share lab3)/urdf/mobile_gazebo.urdf')"/>

  <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
    <param name="use_sim_time" value="true"/>
    <param name="robot_description" value="$(var robot_description)"/>
  </node>

  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-r empty.sdf"/>
  </include>

  <node pkg="controller_manager" exec="spawner"
        args="joint_state_broadcaster"/>

  <node pkg="controller_manager" exec="spawner"
        args="diff_drive_controller"/>

</launch>