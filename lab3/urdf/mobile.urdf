<?xml version="1.0"?>
<robot name="robot_movil">

  <!-- Color of materials -->
  <material name="yellow">
    <color rgba="1 1 0 1"/>
  </material>

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>

  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>

  <material name="black">
  <color rgba="0 0 0 1"/>
  </material>
  
  <!--Aqui se inicia el modelo-->
  <link name="base_link">
    <visual>
      <geometry>
        <!--size="largo ancho alto"-->
        <box size="0.3 0.24 0.05"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="green" />
    </visual>
  </link>

  <joint name="pan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pan_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!--LiDAR del robot movil-->
  <link name="pan_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.02"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <material name="blue" />
    </visual>
  </link>

  <joint name="joint_derecho" type="continuous">
    <parent link="base_link"/>
    <child link="rueda_derecha"/>
    <origin xyz="0 0.14 0"/>
    <axis xyz="0 1 0" />
    <limit effort="300" velocity="0.1"/>
  </joint>

  <joint name="joint_izquierdo" type="continuous">
    <parent link="base_link"/>
    <child link="rueda_izquierda"/>
    <origin xyz="0 -0.14 0"/>
    <axis xyz="0 1 0" />
    <limit effort="300" velocity="0.1"/>
  </joint>
  

  <!--para este caso este sera las ruedas-->
  <link name="rueda_derecha">
    <visual>
      <geometry>
        <cylinder length="0.01" radius="0.04"/>
      </geometry>
      <origin rpy="0 1.5708 1.5708" xyz="0 0 0"/>
      <material name="black" />
    </visual>
  </link>

  <link name="rueda_izquierda">
    <visual>
      <geometry>
        <cylinder length="0.01" radius="0.04"/>
      </geometry>
      <origin rpy="0 1.5708 1.5708" xyz="0 0 0"/>
      <material name="black" />
    </visual>
  </link>

  
</robot>
