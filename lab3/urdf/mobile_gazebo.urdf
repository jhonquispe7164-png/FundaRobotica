<?xml version="1.0"?>
<robot name="robot_movil">

  <!-- =========================
       Materiales
       ========================= -->
  <material name="yellow">
    <color rgba="1 1 0 1"/>
  </material>

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>

  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- =========================
       Link raíz en el piso
       ========================= -->
  <link name="base_footprint"/>

  <!-- =========================
       Chasis principal
       ========================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.3 0.24 0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="green"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.3 0.24 0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0"
               iyy="0.02" iyz="0.0"
               izz="0.02"/>
    </inertial>
  </link>

  <!-- base_link elevado para que las ruedas toquen el piso -->
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       Lidar / sensor superior
       ========================= -->
  <link name="pan_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.02"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.02" radius="0.02"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <joint name="pan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pan_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       Rueda derecha
       ========================= -->
  <link name="rueda_derecha">
    <visual>
      <geometry>
        <cylinder length="0.01" radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 1.5708"/>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.01" radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 1.5708"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_derecho" type="continuous">
    <parent link="base_link"/>
    <child link="rueda_derecha"/>
    <origin xyz="0 0.14 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="300" velocity="20.0"/>
    <dynamics damping="0.2" friction="0.2"/>
  </joint>

  <!-- =========================
       Rueda izquierda
       ========================= -->
  <link name="rueda_izquierda">
    <visual>
      <geometry>
        <cylinder length="0.01" radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 1.5708"/>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.01" radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 1.5708"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint_izquierdo" type="continuous">
    <parent link="base_link"/>
    <child link="rueda_izquierda"/>
    <origin xyz="0 -0.14 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="300" velocity="20.0"/>
    <dynamics damping="0.2" friction="0.2"/>
  </joint>

  <!-- =========================
       Apoyos inferiores rojos
       para estabilidad
       ========================= -->
  <link name="apoyo_frontal">
    <visual>
      <geometry>
        <cylinder length="0.015" radius="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.015" radius="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00002" ixy="0.0" ixz="0.0"
               iyy="0.00002" iyz="0.0"
               izz="0.00002"/>
    </inertial>
  </link>

  <joint name="joint_apoyo_frontal" type="fixed">
    <parent link="base_link"/>
    <child link="apoyo_frontal"/>
    <origin xyz="0.10 0 -0.0325" rpy="0 0 0"/>
  </joint>

  <link name="apoyo_trasero">
    <visual>
      <geometry>
        <cylinder length="0.015" radius="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red"/>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.015" radius="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00002" ixy="0.0" ixz="0.0"
               iyy="0.00002" iyz="0.0"
               izz="0.00002"/>
    </inertial>
  </link>

  <joint name="joint_apoyo_trasero" type="fixed">
    <parent link="base_link"/>
    <child link="apoyo_trasero"/>
    <origin xyz="-0.10 0 -0.0325" rpy="0 0 0"/>
  </joint>

  <!-- =========================
       Parámetros Gazebo
       ========================= -->
  <gazebo reference="rueda_derecha">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>100000.0</kp>
    <kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rueda_izquierda">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>100000.0</kp>
    <kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <gazebo reference="pan_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="apoyo_frontal">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="apoyo_trasero">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <material>Gazebo/Red</material>
  </gazebo>

  <!-- =========================
       ros2_control
       ========================= -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="joint_derecho">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint_izquierdo">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- =========================
       Plugin Gazebo Classic
       ========================= -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find lab3)/config/mobile_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>